# Example environment variables - Copy this file to .env and fill in your own values
# This is a sample file that demonstrates the required environment variables
# 
# NOTE:
# Use placeholders or test values only in this file.
# Production values should be injected through local `.env`, CI secrets,
# or `--dart-define` at build time.

# Required Environment Variables
API_BASE_URL=https://api.artbeat.app
FIREBASE_REGION=us-central1
FIREBASE_PROJECT_ID=wordnerd-artbeat
FIREBASE_FUNCTIONS_BASE_URL=https://us-central1-wordnerd-artbeat.cloudfunctions.net
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_PRODUCT_SPONSORSHIP_ART_WALK=prod_XXXXXXXXXXXXXX
STRIPE_PRICE_SPONSORSHIP_ART_WALK_MONTHLY=price_XXXXXXXXXXXXXX
STRIPE_PRODUCT_SPONSORSHIP_CAPTURE=prod_XXXXXXXXXXXXXX
STRIPE_PRICE_SPONSORSHIP_CAPTURE_MONTHLY=price_XXXXXXXXXXXXXX
STRIPE_PRODUCT_SPONSORSHIP_DISCOVERY=prod_XXXXXXXXXXXXXX
STRIPE_PRICE_SPONSORSHIP_DISCOVERY_MONTHLY=price_XXXXXXXXXXXXXX

# Firebase API Keys
FIREBASE_ANDROID_API_KEY=your_android_api_key_here
FIREBASE_IOS_API_KEY=your_ios_api_key_here
FIREBASE_APP_CHECK_DEBUG_TOKEN=your_app_check_debug_token_here

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Other configuration values can be added here
