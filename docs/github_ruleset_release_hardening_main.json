{
  "name": "Require Release Hardening Gates on main",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/main"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "do_not_enforce_on_create": false,
        "required_status_checks": [
          {
            "context": "Release Hardening Gates"
          }
        ],
        "strict_required_status_checks_policy": true
      }
    }
  ]
}
